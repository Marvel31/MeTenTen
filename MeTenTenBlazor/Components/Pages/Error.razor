@page "/Error"
@using System.Diagnostics

<PageTitle>오류 - MeTenTen</PageTitle>

<div class="error-container">
    <div class="error-content">
        <div class="error-icon">⚠️</div>
        <h1 class="text-danger">오류가 발생했습니다</h1>
        <h2 class="text-danger">요청을 처리하는 중 오류가 발생했습니다.</h2>
        
        @if (ShowRequestId)
        {
            <p>
                <strong>요청 ID:</strong> <code>@RequestId</code>
            </p>
        }

        <div class="error-actions">
            <a href="/" class="btn btn-primary">
                <span class="bi bi-house"></span> 홈으로 돌아가기
            </a>
            <button class="btn btn-outline-secondary" @onclick="RefreshPage">
                <span class="bi bi-arrow-clockwise"></span> 새로고침
            </button>
        </div>

        <div class="error-help">
            <h3>문제가 계속되나요?</h3>
            <p>
                페이지를 새로고침하거나 잠시 후 다시 시도해보세요.
                문제가 지속되면 브라우저 캐시를 삭제해보세요.
            </p>
        </div>
    </div>
</div>

@code{
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        // WebAssembly에서는 Activity.Current?.Id를 사용
        RequestId = Activity.Current?.Id ?? Guid.NewGuid().ToString();
    }

    private void RefreshPage()
    {
        // JavaScript를 통해 페이지 새로고침
        // WebAssembly에서는 직접적인 방법이 제한적이므로 사용자에게 안내
    }
}
