@page "/topics"
@using MeTenTenBlazor.Models
@using MeTenTenBlazor.Services
@inject ITopicService TopicService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>주제 관리 - MeTenTen</PageTitle>

<div class="topics-container">
    <div class="topics-header">
        <h1>📝 주제 관리</h1>
        <p>일일 교환 일기를 위한 주제를 생성하고 관리하세요</p>
        <button class="btn btn-primary" @onclick="ShowCreateModal">
            <span class="bi bi-plus-circle"></span> 새 주제 추가
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (topics.Any())
    {
        <div class="topics-grid">
            @foreach (var topic in topics)
            {
                <div class="topic-card @(topic.IsActive ? "active" : "inactive")">
                    <div class="topic-header">
                        <h3>@topic.Title</h3>
                        <div class="topic-actions">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditTopic(topic)">
                                <span class="bi bi-pencil"></span>
                            </button>
                            <button class="btn btn-sm @(topic.IsActive ? "btn-warning" : "btn-success")" 
                                    @onclick="() => ToggleTopicStatus(topic.Id)">
                                @(topic.IsActive ? "비활성화" : "활성화")
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteTopic(topic.Id)">
                                <span class="bi bi-trash"></span>
                            </button>
                        </div>
                    </div>
                    <p class="topic-description">@topic.Description</p>
                    <div class="topic-footer">
                        <small class="text-muted">
                            생성일: @topic.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                        </small>
                        <span class="badge @(topic.IsActive ? "bg-success" : "bg-secondary")">
                            @(topic.IsActive ? "활성" : "비활성")
                        </span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📝</div>
            <h3>아직 주제가 없습니다</h3>
            <p>첫 번째 주제를 추가해보세요!</p>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <span class="bi bi-plus-circle"></span> 주제 추가하기
            </button>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h5>@(isEditing ? "주제 수정" : "새 주제 추가")</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="currentTopic" OnValidSubmit="SaveTopic">
                    <DataAnnotationsValidator />
                    
                    <div class="form-group">
                        <label for="title">주제 제목 *</label>
                        <InputText id="title" @bind-Value="currentTopic.Title" 
                                  class="form-control" placeholder="예: 오늘 가장 기뻤던 순간" />
                        <ValidationMessage For="@(() => currentTopic.Title)" class="text-danger" />
                    </div>

                    <div class="form-group">
                        <label for="description">주제 설명</label>
                        <InputTextArea id="description" @bind-Value="currentTopic.Description" 
                                     class="form-control" rows="3" 
                                     placeholder="이 주제에 대한 설명을 입력하세요 (선택사항)" />
                        <ValidationMessage For="@(() => currentTopic.Description)" class="text-danger" />
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <div class="modal-actions">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">취소</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            @(isEditing ? "수정" : "추가")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Topic> topics = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private CreateTopicRequest currentTopic = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTopics();
    }

    private async Task LoadTopics()
    {
        isLoading = true;
        try
        {
            topics = await TopicService.GetTopicsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"주제를 불러오는 중 오류가 발생했습니다: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowCreateModal()
    {
        isEditing = false;
        currentTopic = new CreateTopicRequest();
        errorMessage = string.Empty;
        showModal = true;
    }

    private void EditTopic(Topic topic)
    {
        isEditing = true;
        currentTopic = new CreateTopicRequest
        {
            Title = topic.Title,
            Description = topic.Description
        };
        errorMessage = string.Empty;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        isEditing = false;
        currentTopic = new CreateTopicRequest();
        errorMessage = string.Empty;
    }

    private async Task SaveTopic()
    {
        isSaving = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            if (isEditing)
            {
                // TODO: Update topic when API supports it
                // await TopicService.UpdateTopicAsync(topicId, updateRequest);
            }
            else
            {
                await TopicService.CreateTopicAsync(currentTopic);
            }

            await LoadTopics();
            CloseModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"주제 저장 중 오류가 발생했습니다: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ToggleTopicStatus(int topicId)
    {
        try
        {
            var success = await TopicService.ToggleTopicStatusAsync(topicId);
            if (success)
            {
                await LoadTopics();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"주제 상태 변경 중 오류가 발생했습니다: {ex.Message}";
        }
    }

    private async Task DeleteTopic(int topicId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "정말로 이 주제를 삭제하시겠습니까?"))
        {
            try
            {
                var success = await TopicService.DeleteTopicAsync(topicId);
                if (success)
                {
                    await LoadTopics();
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"주제 삭제 중 오류가 발생했습니다: {ex.Message}";
            }
        }
    }
}
